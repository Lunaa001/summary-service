# Database (Docker: use service name 'postgres', Local: use localhost)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=summary_service
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/summary_service

# AI Service - Groq (llama-3.3-70b)
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Server
HOST=0.0.0.0
PORT=8002

# Logging
LOG_LEVEL=INFO

# Database pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Healthcheck
HEALTHCHECK_AI=false
