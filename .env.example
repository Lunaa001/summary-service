# ============================================================================
# Summary Service (AI) — Environment Variables
# This service ONLY generates summaries. No database needed.
# ============================================================================

# AI Service - Groq (llama-3.3-70b-versatile)
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Server
HOST=0.0.0.0
PORT=5000

# Logging
LOG_LEVEL=INFO

# Summary settings
DEFAULT_MAX_TOKENS=2048
MIN_TEXT_LENGTH=100

# Healthcheck (set to true for deep health check incl. AI)
HEALTHCHECK_AI=false

# Redis (for caching)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
