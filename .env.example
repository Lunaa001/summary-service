# Database (Docker: use service name 'postgres', Local: use localhost)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=summary_service
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/summary_service

# AI Service - Gemma4
MODEL_API_KEY=
MODEL_API_BASE_URL=https://ai.cloud.um.edu.ar/api/v1
IA_MODEL=gemma4-26b-16g

# Server
HOST=0.0.0.0
PORT=8002

# Logging
LOG_LEVEL=INFO

# Database pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Healthcheck
HEALTHCHECK_AI=false

